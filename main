#include <WiFi.h>
#include <esp_now.h>
#include <DHT.h>

uint8_t macReceptor[] = {0xB4, 0xBF, 0xE9, 0x32, 0xDF, 0xE4};

typedef struct{
  float nivelTanque = 100.0;
  float temperatura;
  float umidade;
  uint16_t luminosidade;
  bool presencaDetectada = false;
} DadosSensor;

DadosSensor dados;

#define TRIG_PIN 26
#define ECHO_PIN 27
#define LDR_PIN 36
#define PIR_PIN 22
#define LED_VERDE 21
#define LED_VERMELHO 19
#define DHT_PIN 23
#define DHT_TYPE DHT22

DHT dht(DHT_PIN, DHT_TYPE);

float alturaTanque;
float distancia;

void setup() {
  Serial.begin(115200);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
  pinMode(PIR_PIN, INPUT);
  pinMode(LED_VERDE, OUTPUT);
  pinMode(LED_VERMELHO, OUTPUT);
  setupEspNow();
  calibrarAlturaTanque();
  dht.begin();
}

void loop() {
  lerHCSR04();
  lerDHT();
  lerLDR();
  lerHCSR501();
  controleLEDs();
  enviarDados();
  monitorSerial();
}
