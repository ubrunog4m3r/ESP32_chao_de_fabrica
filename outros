void monitorSerial(){
  const unsigned long intervaloMonitorSerial = 5000;
  static unsigned long tempoMonitorSerial = 0;

  if(millis() - tempoMonitorSerial >= intervaloMonitorSerial){
    tempoMonitorSerial = millis();
    if(distancia < 0){
      Serial.println("Erro ao ler HC-SR04");
    }
    else{
      if(dados.nivelTanque >= 20){
        Serial.print("Nivel do tanque: ");
        Serial.print(dados.nivelTanque);
        Serial.println(" %");
      }
      else{
        Serial.println("Alerta! Nível de tinta baixo!");
      }
    }
    if(isnan(dados.temperatura) || isnan(dados.umidade)){
      Serial.println("Erro ao ler DHT");
    }
    else{
      Serial.print("Temperatura: ");
      Serial.print(dados.temperatura);
      Serial.println("°C");
      Serial.print("Umidade: ");
      Serial.print(dados.umidade);
      Serial.println("%");
    }
    Serial.print("Luminosidade: ");
    Serial.println(dados.luminosidade);
    Serial.println(dados.presencaDetectada ? "Presenca detectada!\n" : "Sem presenca detectada\n");
  }
}

void calibrarAlturaTanque(){
  float soma = 0;
  for(int i = 0; i < 10; i++){
    const float velocidadeDoSom = 0.017; // 0.034/2

    digitalWrite(TRIG_PIN, LOW);
    delayMicroseconds(2);
    digitalWrite(TRIG_PIN, HIGH);
    delayMicroseconds(10);
    digitalWrite(TRIG_PIN, LOW);

    unsigned long tempo = pulseIn(ECHO_PIN, HIGH, 10000);

    if(tempo == 0){
      distancia = -1;
    }
    else{
      distancia = tempo * velocidadeDoSom;
    }

    if(distancia > 0){
      soma += distancia;
    }
    else{
      i--;
    }
  }
  alturaTanque = soma / 10;
}

void controleLEDs(){
  bool estadoSistema = dados.nivelTanque >= 20;
  digitalWrite(LED_VERDE, estadoSistema);
  digitalWrite(LED_VERMELHO, !estadoSistema);
}
